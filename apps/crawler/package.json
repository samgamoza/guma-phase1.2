{
  "name": "guma-crawler",
  "version": "1.0.0",
  "description": "Guma AI directory crawler — YellowPages with proxy rotation and BullMQ",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "worker": "node src/queue/worker.js",
    "api": "node src/api.js",
    "crawl": "node src/index.js --run",
    "dev": "node --watch src/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0",
    "bullmq": "^5.7.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.3.2",
    "playwright": "^1.44.0",
    "slugify": "^1.6.6",
    "p-limit": "^5.0.0",
    "winston": "^3.13.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
