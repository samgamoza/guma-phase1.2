# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Redis (BullMQ) — Railway or local
REDIS_URL=redis://localhost:6379

# Proxy — Webshare rotating residential
# Format: http://user:pass@proxy.webshare.io:80
PROXY_LIST=http://user1:pass1@p.webshare.io:80,http://user2:pass2@p.webshare.io:80

# Crawler settings
CRAWL_CONCURRENCY=3
CRAWL_DELAY_MS=3000
REQUESTS_PER_MINUTE=20
MAX_RETRIES=3

# Optional: Slack webhook for alerts
SLACK_WEBHOOK_URL=
